---
/**
 * Animated hero background: random-walk paths quietly drifting left on a
 * fine grid — purely decorative (aria-hidden), canvas behind the content.
 *
 * Behavior:
 *  - prefers-reduced-motion: a static image, no animation.
 *  - Tab hidden / hero outside the viewport: animation pauses.
 *  - Without JS the background simply stays empty (only the hero's CSS grid).
 */
---

<canvas class="market-bg" id="market-bg" aria-hidden="true"></canvas>

<script>
  const canvas = document.getElementById("market-bg") as HTMLCanvasElement | null;

  if (canvas) {
    const ctx = canvas.getContext("2d")!;
    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const css = getComputedStyle(document.documentElement);
    const color = (name: string, fallback: string) =>
      css.getPropertyValue(name).trim() || fallback;

    // Line colors: one accent line, one market-green line, the rest neutral.
    const PALETTE = [
      { stroke: color("--accent", "#ff5c72"), alpha: 0.5, width: 1.6, fill: true },
      { stroke: color("--up", "#2fbf8f"), alpha: 0.32, width: 1.2, fill: false },
      { stroke: "#8fa0b4", alpha: 0.16, width: 1, fill: false },
      { stroke: "#8fa0b4", alpha: 0.12, width: 1, fill: false },
      { stroke: color("--accent", "#ff5c72"), alpha: 0.14, width: 1, fill: false },
    ];

    const DX = 7; // horizontal spacing between two points, in px

    type Series = {
      pts: number[];
      y: number; // current value (0..1, fraction of height)
      anchor: number; // mean value the path is pulled back toward
      vol: number;
      speed: number; // px per ms drift to the left
      offset: number;
      cfg: (typeof PALETTE)[number];
    };

    let series: Series[] = [];
    let w = 0;
    let h = 0;

    const randn = () => {
      let u = 0;
      let v = 0;
      while (u === 0) u = Math.random();
      while (v === 0) v = Math.random();
      return Math.sqrt(-2 * Math.log(u)) * Math.cos(2 * Math.PI * v);
    };

    const nextY = (s: Series) => {
      // Random walk with a slight pull back to the anchor so nothing drifts off.
      s.y += s.vol * randn() + (s.anchor - s.y) * 0.02;
      s.y = Math.min(0.92, Math.max(0.08, s.y));
      return s.y;
    };

    const advance = (s: Series) => {
      s.pts.push(nextY(s));
      s.pts.shift();
    };

    const buildSeries = () => {
      const n = Math.ceil(w / DX) + 3;
      series = PALETTE.map((cfg, i) => {
        const anchor = 0.25 + (0.55 * i) / (PALETTE.length - 1);
        const s: Series = {
          pts: [],
          y: anchor,
          anchor,
          vol: 0.014 + Math.random() * 0.012,
          speed: 0.008 + Math.random() * 0.008,
          offset: 0,
          cfg,
        };
        for (let j = 0; j < n; j++) s.pts.push(nextY(s));
        return s;
      });
    };

    const fit = () => {
      const parent = canvas.parentElement!;
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      w = parent.clientWidth;
      h = parent.clientHeight;
      canvas.width = Math.round(w * dpr);
      canvas.height = Math.round(h * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      buildSeries();
    };

    const draw = () => {
      ctx.clearRect(0, 0, w, h);

      for (const s of series) {
        ctx.save();
        ctx.translate(-s.offset, 0);
        ctx.globalAlpha = s.cfg.alpha;
        ctx.strokeStyle = s.cfg.stroke;
        ctx.lineWidth = s.cfg.width;
        ctx.lineJoin = "round";

        ctx.beginPath();
        for (let i = 0; i < s.pts.length; i++) {
          const x = i * DX;
          const y = s.pts[i] * h;
          if (i === 0) ctx.moveTo(x, y);
          else ctx.lineTo(x, y);
        }
        ctx.stroke();

        // Area under the main line for a bit of depth.
        if (s.cfg.fill) {
          ctx.globalAlpha = 0.05;
          ctx.lineTo((s.pts.length - 1) * DX, h);
          ctx.lineTo(0, h);
          ctx.closePath();
          ctx.fillStyle = s.cfg.stroke;
          ctx.fill();
        }
        ctx.restore();
      }
    };

    let running = false;
    let rafId = 0;
    let last = 0;

    const frame = (t: number) => {
      if (!running) return;
      const dt = Math.min(t - last, 100);
      last = t;
      for (const s of series) {
        s.offset += s.speed * dt;
        while (s.offset >= DX) {
          s.offset -= DX;
          advance(s);
        }
      }
      draw();
      rafId = requestAnimationFrame(frame);
    };

    const start = () => {
      if (running || reduced) return;
      running = true;
      last = performance.now();
      rafId = requestAnimationFrame(frame);
    };

    const stop = () => {
      running = false;
      cancelAnimationFrame(rafId);
    };

    fit();
    draw();

    if (!reduced) {
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) e.isIntersecting ? start() : stop();
        },
        { threshold: 0 }
      );
      io.observe(canvas);

      document.addEventListener("visibilitychange", () => {
        document.hidden ? stop() : start();
      });
    }

    let resizeTimer = 0;
    window.addEventListener("resize", () => {
      clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(() => {
        fit();
        draw();
      }, 150);
    });
  }
</script>

<style>
  .market-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }
</style>
