---
/**
 * Legal notice (English) — served at "/en/impressum".
 *
 * Convenience translation of src/pages/impressum.astro. The German version is
 * the legally authoritative one (§5 DDG); a note at the top links to it.
 * The same TODO placeholders from config.impressum apply here (§16.3).
 */
import Base from "../../layouts/Base.astro";
import { impressum, kontakt, wortmarke } from "../../config";
import { localePath } from "../../i18n";

const titel = `Legal notice — ${wortmarke.lang}`;
const germanHref = localePath("de", "impressum");
---

<Base titel={titel} beschreibung="Legal notice of the Tübingen Quant Society.">
  <section class="section" aria-labelledby="impressum-headline">
    <div class="section__inner">
      <div class="prose">
        <h1 class="section-headline" id="impressum-headline">Legal notice</h1>

        <div class="body">
          <p class="hinweis">
            This is a convenience translation. The legally binding version is the{" "}
            <a class="link" href={germanHref}>German legal notice</a>.
          </p>

          <p>
            {wortmarke.lang}<br />
            A student initiative at the University of Tübingen<br />
            {impressum.land}
          </p>

          <h2 class="h3">Contact</h2>
          <p>
            <a class="link" href={`mailto:${kontakt.mail}`}>{kontakt.mail}</a>
          </p>

          <h2 class="h3">Liability for content</h2>
          <p>
            As a service provider, we are responsible for our own content on these pages
            under the general laws. We are not obliged to monitor transmitted or stored
            third-party information, or to investigate circumstances that indicate unlawful
            activity.
          </p>

          <h2 class="h3">Liability for links</h2>
          <p>
            Our offering contains links to external third-party websites whose content we
            have no influence over. The respective provider or operator of the linked pages
            is always responsible for their content.
          </p>

          <h2 class="h3">Note on the University of Tübingen</h2>
          <p>
            The {wortmarke.lang} is a student initiative at the University of Tübingen. It is
            not a body of the university, and the university is not responsible for its
            content.
          </p>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .body {
    margin-top: var(--space-6);
    color: var(--ink-muted);
  }

  .h3 {
    font-size: var(--fs-h3);
    font-weight: 600;
    color: var(--ink);
    margin-top: var(--space-6);
    margin-bottom: var(--space-2);
  }

  .body > .h3:first-child {
    margin-top: 0;
  }

  .hinweis {
    border-left: 2px solid var(--rule);
    padding-left: var(--space-4);
    font-size: var(--fs-small);
    margin-bottom: var(--space-6);
  }
</style>
